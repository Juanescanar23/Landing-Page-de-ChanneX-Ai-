{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "builds": [
    { "src": "channexai-v3.html", "use": "@vercel/static" },
    { "src": "gracias.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/gracias", "dest": "/gracias.html" },
    { "src": "/gracias/", "dest": "/gracias.html" },
    { "src": "/(.*)", "dest": "/channexai-v3.html" }
  ]
}
